import matplotlib.pyplot as plt
import numpy as np
overs=np.arange(1,20)
scores=[10,30,20,5,11,33,16,27,9,11,25,33,4,22,20,5,9,12,15,]
plt.bar(overs,scores,color="pink")
plt.title("INDIA'S SCORES (bar chart)")
plt.xlabel("over number")
plt.ylabel("runs scored")
plt.xticks(overs)
plt.grid(axis='y',linestyle='--',alpha=0.9)
plt.show()
