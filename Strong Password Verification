a=input("Enter you password:")
up=0
sm=0
dg=0
sp=0
if(len(a)>7):
    for i in a:
        if i.isupper():
            up=up+1
        elif i.islower():
            sm=sm+1
        elif i.isdigit():
            dg=dg+1
        else:
            sp=sp+1
            
    if(up>0 and sm>0 and dg>0 and sp>0):
        print("Strong Password!!")
    else:
        print("Weak!!")
else:
    print("Password will be in 8 characters!!")